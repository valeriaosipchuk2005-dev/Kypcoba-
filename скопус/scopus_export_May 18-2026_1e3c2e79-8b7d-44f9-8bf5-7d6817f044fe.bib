@ARTICLE{Barana2024227,
	author = {Barana, Alice and Marchisio Conte, Marina},
	title = {Promoting socioeconomic equity through automatic formative assessment},
	year = {2024},
	journal = {Journal on Mathematics Education},
	volume = {15},
	number = {1},
	pages = {227 - 252},
	doi = {10.22342/jme.v15i1.pp227-252},
	url = {https://www.scopus.com/pages/publications/85180088549?origin=resultslist},
	abstract = {Ensuring equity in education is a goal for sustainable development. Among the factors that hinder equity, socioeconomic status (SES) has the highest impact on learning Mathematics. This paper addresses the issue of equity at the secondary school level by proposing an approach based on adopting automatic formative assessment (AFA). Carefully designed mathematical activities with interactive feedback were experimented with a sample of 299 students of grade 8 for a school year. A control group of 257 students learned the same topics using traditional methodologies. Part of the sample belonged to low SES. The learning achievement was assessed through pre-and post-tests to understand if the adoption of AFA impacted learning and whether the results depended on the students’ SES. The results show a positive effect of the experimentation (effect size: 0.42). Moreover, the effect size of the experimentation restricted to the low-SES group is high (0.77). In the treatment group, the results do not depend on SES, while in the control group, they do, suggesting that AFA is an equitable approach while traditional instruction risks perpetuating inequalities. © The Author(s) 2024.},
	author_keywords = {Automatic Assessment; Digital Learning Environment; Equity; Formative Assessment; Socioeconomic Status},
	type = {Letter},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 5; All Open Access; Gold Open Access}
}

