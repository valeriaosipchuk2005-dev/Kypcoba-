@BOOK{Sangwin2026207,
	author = {Sangwin, Christopher and Oyengo, Michael O.},
	title = {USING COMPUTER ALGEBRA TO SUPPORT AUTOMATIC ASSESSMENT OF MATHEMATICS},
	year = {2026},
	journal = {Digital Technology and Artificial Intelligence in Mathematics Education Assessment},
	pages = {207 - 225},
	doi = {10.4324/9781003533764-12},
	url = {https://www.scopus.com/pages/publications/105029000294?origin=resultslist},
	abstract = {For over a quarter of a century, computer algebra systems have been utilised in assessment systems to transition away from multiple-choice questions towards enabling automatic assessment of students’ answers which are student-constructed mathematical expressions. Objective properties of these expressions are then established automatically, and the software generates outcomes including numerical marks, formative feedback, and detailed statistical information. The advantages of these systems include providing students with immediate, personalised, and adaptive learning experiences, which help them identify and potentially correct mistakes more quickly. Despite these benefits, such software still has significant limitations compared to human tutors, including the inability to offer subjective feedback or engage in meaningful dialogue with students. However, it excels in providing consistency, scalability, and efficiency, allowing for assessments to be conducted on a large scale. Overall, the implementation of automatic assessment, supported by computer algebra, has started to influence the field of mathematics education, offering new possibilities for personalised and adaptive learning experiences. This includes high-stakes examinations. This chapter provides a review of a quarter of a century of use and contemporary examples and discusses the future of this field in the context of emerging generative AI. © 2026 selection and editorial matter, Eirini Geraniou, Cosette Crisan, and Manolis Mavrikis; individual chapters, the contributors.},
	keywords = {Education computing; Feedback; Students; Adaptive learning; Assessment system; Automatic assessment; Computer algebra; Computer algebra systems; Learning experiences; Mathematical expressions; Multiple-choice questions; Personalized learning; Property; Algebra},
	type = {Book chapter},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 0}
}

