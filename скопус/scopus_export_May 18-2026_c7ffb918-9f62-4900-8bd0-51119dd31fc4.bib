@ARTICLE{Chen2025,
	author = {Chen, Yuchen and Zhang, Xinli and Tu, Yun-Fang and Hwang, Gwo-Jen and Hu, Lailin},
	title = {Conceptions of image-generative AI-supported instruction of preservice teachers with different levels of learning attitude: a drawing and epistemic network analysis},
	year = {2025},
	journal = {Journal of Research on Technology in Education},
	pages = {},
	doi = {10.1080/15391523.2025.2478433},
	url = {https://www.scopus.com/pages/publications/105000908013?origin=resultslist},
	abstract = {This study explored 106 Chinese pre-service teachers’ (PSTs’) conceptions of image-generative artificial intelligence (image-GAI) supported instruction and how their conceptions differed by learning attitudes. The draw-a-picture technique was employed for PSTs to convey their ideas through drawings. A coding checklist with six categories was developed to code PSTs’ drawing features. Epistemic network analysis (ENA) was then utilized to visualize PSTs’ conceptual model. Results revealed that most PSTs conceptualized that image-GAI was an ideal tool for teachers lecturing on specific content (e.g. language, arts, mathematics, science) to students in the classroom. Additionally, PSTs with different learning attitudes held different conceptions in categories of participants, activities, content, and objects. In particular, the more positive learning attitude (MPLA) group tended to conceptualize students using image-GAI to visualize specific learning content, while the less positive learning attitude (LPLA) group tended to conceptualize teachers using image-GAI for lectures. Moreover, regarding the benefits and concerns of image-GAI-supported instruction: (1) Both groups perceived the merits of image-GAI in elevating learning efficiency, perceptions, experience, higher-order thinking, and teaching quality; (2) Both groups perceived the concerns of image-GAI in over-dependence, technical limitations, and ethical and moral issues; and (3) Only the MPLA group mentioned that image-GAI may threaten teachers’ profession. Findings from this study can provide valuable implications for teachers’ professional training and future research on image-GAI-supported instruction. © 2025 ISTE.},
	author_keywords = {Draw-a-picture technique; Drawing analysis; Epistemic network analysis (ENA); Image-generative artificial intelligence (image-GAI); Pre-service teacher},
	type = {Article},
	publication_stage = {Article in press},
	source = {Scopus},
	note = {Cited by: 3}
}

@BOOK{Byers20251,
