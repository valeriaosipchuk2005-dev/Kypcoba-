	abstract = {The ubiquity of artificial intelligence (AI) is transforming education, with Science, Technology, Engineering, Arts, and Mathematics (STEAM) education emerging as a particularly promising area for its integration. European University Cyprus offers an at-distance postgraduate course “Applications of New Technologies in STEAM Education,” which includes a dedicated module “AI in STEAM Education.” The module combines asynchronous learning, online materials, and synchronous sessions to engage postgraduate students—both pre-service and in-service teachers— with core AI concepts, ethical considerations, and practical pedagogical applications. Its aim is to equip participants with the knowledge and skills necessary to effectively integrate AI into STEAM curricula, while also deepening their understanding of AI’s dual role in education: its transformative potential and the need for careful, ethical integration. The chapter outlines the module content and structure and presents the results of an online post-survey study, which explored participants’ (n = 75) experiences from the module and perceptions of AI and the use of AI-based educational applications in STEAM education. Few studies have specifically explored postgraduate teachers’ perspectives within such a dedicated module, making this research especially valuable. The results indicate strong enthusiasm for AI’s transformative educational potential, tempered by concerns about ethical issues, the need for teacher training, and the readiness of educational institutions in terms of infrastructure. Findings underscore how a well-designed curriculum can empower educators with essential skills and ethical awareness, offering insights for developing similar programs and advancing the field, while also emphasizing the need for further research on the methodological integration of AI in education. © The Author(s), under exclusive license to Springer Nature Switzerland AG 2025.},
	author_keywords = {AI-enhanced learning; Artificial intelligence; Emerging technologies; Pre-service teachers; STEAM Education; Student teachers; Teachers},
	keywords = {Curricula; E-learning; Education computing; Engineering education; Ethical aspects; Integration; Personnel training; Steam; Students; Teaching; Art educations; Artificial intelligence-enhanced learning; Emerging technologies; Enhanced learning; Mathematics education; Preservice teachers; Science education; Science technologies; Student teachers; Teachers'; Technology education; Artificial intelligence},
	type = {Book chapter},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 1}
}

@ARTICLE{Marzano2025,
	author = {Marzano, Daniela},
	title = {Generative Artificial Intelligence (GAI) in Teaching and Learning Processes at the K-12 Level: A Systematic Review},
	year = {2025},
	journal = {Technology, Knowledge and Learning},
	pages = {},
	doi = {10.1007/s10758-025-09853-7},
	url = {https://www.scopus.com/pages/publications/105008394742?origin=resultslist},
	abstract = {This systematic review aims to provide a detailed and comprehensive overview of the use of Generative Artificial Intelligence (GAI) in K-12 education. Using the PRISMA method, this research examined articles published between 2016 and 2024, selecting 197 relevant studies from 5 databases and 2 journals. The methodology included the use of the Mentefacto Map to identify keywords and define inclusion and exclusion criteria, ensuring a systematic and replicable approach. The findings of the review indicate that GAI offers significant opportunities to personalize learning experiences, motivate students, improve assessment methods, and introduce innovative and immersive teaching practices. The use of ChatGPT in educational environments is a clear example of this. There are several critical issues that need attention, such as the need for continuous teacher training on ICT and the development of ministerial guidelines that also address ethical and privacy concerns. There is a notable lack of concrete studies and specific experiments, not only focused on STEM disciplines but also open to the arts/humanities, as well as practical examples of GAI use in daily teaching practices, which should guide educators in selecting the most suitable educational technologies for their teaching objectives. An original contribution of this review lies in identifying specific gaps in the existing literature, along with the proposal of research perspectives and insights that have so far been underexplored. © The Author(s) 2025.},
	author_keywords = {AI for education and AI tools; AI methods; Artificial Intelligence; Artificial Intelligence in Education (AIEd); Educational technologies; GAI for education and GAI tools—ChatGPT; Generative Artificial Intelligence; Teaching AI},
	keywords = {Education computing; Educational technology; Engineering education; Learning systems; Personnel training; STEM (science, technology, engineering and mathematics); Teaching; AI for education and AI tool; AI method; Artificial intelligence in education; Artificial intelligence tools; Generative artificial intelligence; Generative artificial intelligence for education and generative artificial intelligence tool—ChatGPT; Systematic Review; Teaching AI; Teaching practices; Artificial intelligence},
	type = {Article},
	publication_stage = {Article in press},
	source = {Scopus},
	note = {Cited by: 19; All Open Access; Hybrid Gold Open Access}
}

