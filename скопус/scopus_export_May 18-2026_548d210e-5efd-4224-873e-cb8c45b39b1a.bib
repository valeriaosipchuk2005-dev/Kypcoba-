@ARTICLE{Naseer2025,
	author = {Naseer, Fawad and Khawaja, Sarwar},
	title = {Mitigating Conceptual Learning Gaps in Mixed-Ability Classrooms: A Learning Analytics-Based Evaluation of AI-Driven Adaptive Feedback for Struggling Learners},
	year = {2025},
	journal = {Applied Sciences (Switzerland)},
	volume = {15},
