@CONFERENCE{Banweer2025,
	author = {Banweer, Keerti and Trytten, Deborah},
	title = {A Qualitative Study of How Computer Science Students Develop Debugging Skills in a Curriculum},
	year = {2025},
	journal = {Proceedings - Frontiers in Education Conference, FIE},
