@ARTICLE{Lee2025,
	author = {Lee, Dabae and Son, Taekwon and Yeo, Sheunghyun},
	title = {Impacts of interacting with an AI chatbot on preservice teachers' responsive teaching skills in math education},
	year = {2025},
	journal = {Journal of Computer Assisted Learning},
