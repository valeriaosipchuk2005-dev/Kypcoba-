@CONFERENCE{Cheon2025415,
	author = {Cheon, Serene and Kang, Hyo},
	title = {Exploring Design Directions for AI Teaching Assistants in Virtual Science Labs},
	year = {2025},
	journal = {Proceedings of the ACM Conference on Computer Supported Cooperative Work, CSCW},
	pages = {415 - 420},
	doi = {10.1145/3715070.3749263},
	url = {https://www.scopus.com/pages/publications/105031893693?origin=resultslist},
	abstract = {Virtual science laboratories have gained traction in STEM education, yet replicating the real-time instructional support typically provided by human instructors remains a key challenge. To address this, we developed a virtual science lab integrating a GPT-4–powered AI teaching assistant (AI-TA) that delivers scripted instruction and responds to learner questions through a custom chat interface. This preliminary study explores learners’ perceptions of the AI-TA, focusing on perceived benefits, limitations, and recommendations for future design. We conducted in-depth interviews and participatory design sessions with nine engineering students who had prior laboratory experience. Findings suggest that participants valued the AI-TA for its constant availability, reduced fear of judgment, and the increased engagement enabled by its 3D presence within the learning environment—benefits that go beyond traditional text-based chat systems. However, participants raised concerns about the accuracy of AI responses and the lack of seamless integration between chat interaction and instructional flow. Suggested improvements included smoother transitions between instruction and chat, context-aware support based on user activity, and more proactive engagement through structured AI prompts rather than relying solely on learner-initiated questions. These insights offer guidance for future development of AI-assisted virtual science labs. © 2025 Copyright held by the owner/author(s).},
	author_keywords = {AI Virtual Assistant; GPT; Pedagogical Agent; Virtual Science Lab},
	keywords = {Artificial intelligence; Chatbots; Computer aided instruction; E-learning; Human computer interaction; Human engineering; Laboratories; Learning systems; STEM (science, technology, engineering and mathematics); Teaching; Virtual reality; AI virtual assistant; GPT; Instructional support; Pedagogical agents; Real- time; Science laboratories; STEM education; Teaching assistants; Virtual assistants; Virtual science lab; Virtual addresses},
	type = {Conference paper},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 1}
}

@CONFERENCE{Randall202595,
	author = {Randall, Andre Kenneth Chase},
	title = {A Synthesis Proposal: Merging AI in Education with Automata Theory},
	year = {2025},
	journal = {CEUR Workshop Proceedings},
	volume = {3927},
	pages = {95 - 103},
	url = {https://www.scopus.com/pages/publications/85219608483?origin=resultslist},
	abstract = {As classroom sizes expand, formal education faces increased challenges in providing scalable, targeted feedback based on student engagement. CS250, an undergraduate core course in discrete mathematics, covers topics such as logic, elementary number theory, proof by induction, recursion on trees, search algorithms, regular languages, finite state machines, and computability. These concepts often present challenges due to their abstract nature and the precision required in logical reasoning. Primarily enrolling computer science and related majors, the course benefits from reusable learning objects (RLOs) designed to support concept mastery. In this context, the author proposed a new discussion material on mathematical foundations, specifically targeting regular language expression. He tested a Python tool that allowed students to check their answers' correctness while mastering regular language expressions. Students completed the Python tool and a survey, which confirmed the tool's usefulness and provided valuable feedback for iterative design. This paper aims to contribute to the existing body of knowledge on AI in education by shedding light on student perspectives with RLOs. In future iterations, we plan to recruit a more diverse range of educators, including female educators from all-women colleges, to broaden our perspective on instructional effectiveness. Moving forward, we seek to explore the balance between technological and human interventions required for effective course delivery. Although these findings are preliminary, continued research and richer data may reveal organic, inductive themes as this iterative process unfolds.  © 2023 Copyright for this paper by its authors.},
	author_keywords = {AI in Education; Automata Theory; Doctoral Consortium; Regular Expressions; Reusable Learning Objects (RLOs); Synthesis Proposal},
	keywords = {Computer software reusability; Contrastive Learning; Curricula; Finite automata; Problem oriented languages; Python; Reusability; Teaching; AI in education; Core course; Doctoral consortium; Feed-back based; Formal education; Regular expressions; Reusable learning object; Student engagement; Synthesis proposal; Students},
	type = {Conference paper},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 0}
}

@CONFERENCE{Feyijimi2025,
	author = {Feyijimi, Taiwo and Bork, Sarah Jane},
	title = {Chain-of-Thought Prompting with Large Language Models for Inclusive Learning: Advancing Problem-Solving in Engineering Education and Research},
	year = {2025},
	journal = {2025 15th IEEE Integrated STEM Education Conference, ISEC 2025},
	pages = {},
	doi = {10.1109/ISEC64801.2025.11460331},
	url = {https://www.scopus.com/pages/publications/105036370953?origin=resultslist},
	abstract = {This conceptual paper presents an innovative framework for integrating Chain-of-Thought (CoT) prompting within engineering education to enhance the understanding, assessment, and facilitation of complex problem-solving skills. Traditional assessment methods often focus on final answers, overlooking the critical reasoning steps that reveal cognitive barriers and provide valuable insights for tailored pedagogical interventions. By utilizing the advanced reasoning capabilities of Large Language Models (LLMs), CoT prompting guides students through structured and iterative problem- solving processes, cultivating metacognitive awareness and fostering a deeper engagement with engineering concepts. The proposed CoT prompting with LLM (CoT- LLM) framework not only assesses the outcomes of problem-solving but also emphasizes the reasoning pathways students undertake, offering a dual lens for evaluation. This approach bridges cognitive science, engineering pedagogy, and AI methodologies, enabling educators to identify reasoning gaps and develop equity-focused teaching strategies. Furthermore, the CoT-LLM framework mitigates the risks of overreliance on AI tools by reinforcing human-centered problem-solving skills, ensuring students remain at the core of the learning process. This paper highlights the transformative potential of CoT prompting to democratize STEM education, particularly in resource-constrained settings where traditional teaching methods may be limited. By emphasizing transparent and inclusive learning processes, the CoT-LLM framework offers a pathway to address critical educational inequities. Ultimately, this work advocates for a paradigm shift in STEM education - one that integrates advanced AI-driven techniques to foster a more inclusive, equitable, and effective educational landscape, equipping students with the cognitive and collaborative tools necessary for real-world engineering challenges.  © 2025 IEEE.},
	author_keywords = {Chain-of-Thought Prompting; Engineering Education Research; Equity in STEM Education; Large Language Models (LLMs); Metacognition and Self-Regulation},
	keywords = {Artificial intelligence; Education computing; Engineering education; Engineering research; Human engineering; Learning systems; STEM (science, technology, engineering and mathematics); Teaching; Chain-of-thought prompting; Engineering education research; Equity in STEM education; Language model; Large language model; Metacognition; Metacognition and self-regulation; Modelling framework; Self regulation; STEM education; Students},
	type = {Conference paper},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 0}
}

@ARTICLE{Gunpinar2025,
	author = {Gunpinar, Yasemin and Sung, Woonhee},
	title = {Exploring 2D Geometric Shape Classification Using AI-Driven Feature Tables in Mathematics},
	year = {2025},
	journal = {School Science and Mathematics},
	pages = {},
	doi = {10.1111/ssm.70003},
	url = {https://www.scopus.com/pages/publications/105025593239?origin=resultslist},
	abstract = {This study explored the effectiveness of an AI-integrated instructional task designed to enhance preservice teachers' understanding of the features and hierarchical relationships of 2D geometric shapes. Originally developed and tested in online K-12 professional development settings, this intervention was adapted for in-person preservice teacher education context in this study. Data were collected from 17 preservice teachers through demographic surveys, pre- and posttests using the Van Hiele geometry framework, hierarchical diagram tasks, feature table creation during the intervention, and postintervention reflections. Findings indicated a statistically significant improvement in the accuracy and complexity of postintervention hierarchical diagrams, along with a descriptively higher mean score on the posttest of Van Hiele geometry content knowledge. Postintervention diagram classifications revealed a greater number of participants achieving the highest level of understanding of hierarchical relationships. Thematic analysis of participants' reflections suggested an increased awareness of AI integration in teaching and a deeper conceptual understanding of classification and hierarchy. This study highlights a practical approach for future educators to incorporate AI concepts into mathematics instruction, supporting the connection between abstract geometric ideas and real-world applications. © 2025 The Author(s). School Science and Mathematics published by Wiley Periodicals LLC on behalf of School Science and Mathematics Association.},
	author_keywords = {2D geometric shapes; artificial intelligence; hierarchical diagrams; preservice teachers},
	type = {Article},
	publication_stage = {Article in press},
	source = {Scopus},
	note = {Cited by: 0; All Open Access; Hybrid Gold Open Access}
}

@CONFERENCE{Zhang2025,
