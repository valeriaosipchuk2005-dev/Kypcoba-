	note = {Cited by: 1; All Open Access; Gold Open Access}
}

@CONFERENCE{San2025335,
	author = {San, Zhizhuoma and Jia, La Ma},
	title = {Adaptive Learning Framework for Ethnic Education in Minority Regions Using Reinforcement Learning},
	year = {2025},
	journal = {Proceedings of 2025 2nd International Conference on Informatics Education and Computer Technology Applications, IECA 2025},
	pages = {335 - 340},
	doi = {10.1145/3732801.3732861},
	url = {https://www.scopus.com/pages/publications/105011584110?origin=resultslist},
	abstract = {In the current context of the development of data science and big data, the development of educational information is also becoming faster and faster. Therefore, we provide students from different cultural backgrounds with corresponding personalized and adaptive learning methods. The learning path is a key development direction in the field of smart education in recent years. This paper proposes an adaptive education and teaching system based on deep learning. This system optimizes the personalized learning path and education and teaching resource allocation for ethnic minority areas through real-time feedback and adjustment. Our article selected an ethnic middle school in Maoxian County, Sichuan Province as the experimental subject of this experiment. This school has 300 students from several ethnic minority backgrounds such as Tibetan, Qiang and Hui. There are definitely obvious differences in cultural background and learning characteristics of the students due to ethnic reasons. In order to test the adaptability of this system in a multicultural context, we did a lot of experiments. The results show that through this adaptive teaching system, these ethnic minority students have improved in subjects such as mathematics, Chinese and English. The grades of students have been significantly improved, and the accuracy of personalized learning path recommendations for them has reached more than 90%. The adaptability of educational resources for teachers has also been correspondingly improved. Therefore, based on the adaptive education system of reinforcement learning, we have proved that it can effectively improve the fairness of education in ethnic areas, as well as the learning outcomes and effects, especially in terms of different cultural backgrounds. Its performance is good. In addition, our article also discusses the advantages of our system in different ethnic areas and the paths that can improve the quality of education, especially in areas where educational resources are relatively scarce and where the literature and culture are diverse. Therefore, through the effective combination of personalized learning path recommendations and educational resources, our system can improve students’ learning efficiency and academic performance, while also making effective adjustments based on the cultural backgrounds and ethnic backgrounds of different students. This will further promote the improvement of educational fairness and quality. © 2025 Copyright held by the owner/author(s).},
	author_keywords = {adaptive education2; cultural adaptation4; Deep Q-learning1; educational resource optimization5; personalized learning path3},
	keywords = {Big data; Deep learning; Education computing; Learning systems; Resource allocation; Students; Teaching; Adaptive education2; Cultural adaptation4; Cultural backgrounds; Deep Q-learning1; Educational resource; Educational resource optimization5; Ethnic minorities; Learning paths; Personalized learning; Personalized learning path3; Reinforcement learning},
	type = {Conference paper},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 0; All Open Access; Gold Open Access}
}

