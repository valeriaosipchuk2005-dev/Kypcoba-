@ARTICLE{Pathania2025,
	author = {Pathania, Manisha and Singh, Chander Partap and Kaur, Deepti Prit and Mantri, Archana},
	title = {Effects of Self-Adaptive Approach of Iterative Game Based Learning on Performance and Satisfaction of Elementary School Students in Mathematics: An Action Research Field Experiment},
	year = {2025},
	journal = {SN Computer Science},
	volume = {6},
	number = {5},
	pages = {},
	doi = {10.1007/s42979-025-04071-5},
	url = {https://www.scopus.com/pages/publications/105007191450?origin=resultslist},
	abstract = {Elementary education is the most essential part for a student to learn and build concepts that last for a lifetime. However, many young learners find it difficult to get a grasp on mathematics from the early stages themselves. To overcome the fear of mathematics in beginners’ minds, researchers have put forth a rather intriguing method called ‘game-based learning’ which provides an interactive and interesting environment to learn. However, different individuals may not have the same level of understanding of the same levels in the game. This research article proposes a novel framework that leverages a self-adaptive iterative gamification approach for both learning and assessment of elementary mathematics concepts. The framework is designed to dynamically adjust gamification elements based on students' learning progress and preferences, fostering personalized learning experiences. It employs iterative cycles of gamification design, implementation, evaluation, and adaptation to continuously refine and optimize the learning environment. The proposed framework is supported by a theoretical foundation rooted in educational psychology, game design principles, and adaptive learning theories. It aims to address the challenges associated with traditional approaches to teaching and assessing elementary mathematics by fostering active student participation, intrinsic motivation, and mastery-oriented learning behaviours. The effectiveness of the framework is evaluated through empirical studies conducted in real educational settings, involving 73 elementary school students divided into experimental and control groups. The results (t[71] = 6.1, p < 0.01) indicated a substantial student satisfaction and improvement in the performance of the experimental group (F = 5.25, p < 0.05), confirming that the adaptive game-based approach not only enhances learning outcomes but also boosts student engagement. The adaptive nature of the framework ensures that it can cater to diverse learning needs, making it a valuable asset for educators aiming to foster both academic achievement and intrinsic motivation among young learners. © The Author(s), under exclusive licence to Springer Nature Singapore Pte Ltd. 2025.},
	author_keywords = {Adaptive learning; Basic mathematics; Elementary education; Gamification of mathematics; Technology in education},
	type = {Article},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 2}
}

@CONFERENCE{Wongkampha2025,
	author = {Wongkampha, Taksaya and Chaijaroen, Sumalee and Junpeng, Putcharee},
	title = {Effects of Constructivist Web-based Learning Environment to Enhance Problem-solving in Mathematics Regarding Two-dimensional and Three-dimensional Geometry},
	year = {2025},
	journal = {2025 International Technical Conference on Circuits/Systems, Computers, and Communications, ITC-CSCC 2025},
	pages = {},
	doi = {10.1109/ITC-CSCC66376.2025.11137796},
	url = {https://www.scopus.com/pages/publications/105016414811?origin=resultslist},
	abstract = {Assessing students' mathematical problem-solving skills is a crucial responsibility for educators. The integration of modern technology with mathematical processes presents an innovative approach to designing learning environments that enhance students' mathematical problem-solving abilities. This research aimed to study the mathematical problem-solving abilities of students who learned through a constructivist web-based learning environment on two-dimensional and three-dimensional geometry, and to enhance students' mathematical problem-solving in two-dimensional and three-dimensional geometry. The sample consisted of 35 Grade 7 students from class 1/4 at Khon Kaen University Demonstration Secondary School (Suksasart), who were enrolled in the Additional Mathematics course during the first semester of the 2022 academic year. The research employed a developmental research design, consisting of three phases: design, development, and evaluation. The emphasis was on constructing an adaptive learning environment. Two main types of research instruments were utilized: (1) a creatively designed web-based learning environment aimed at enhancing problem-solving abilities in the context of two- and three-dimensional geometry, comprising five core components: problem-based learning, resources, scaffolding, collaboration, and coaching; and (2) data collection tools, including a subjective problem-solving test based on Polya's four-step problem-solving process and an objective test to assess overall content knowledge. Data were analyzed using percentage, mean, and standard deviation. The findings revealed that students demonstrated a more structured and systematic approach to solving mathematical problems following Polya's process, leading to greater accuracy and thoughtfulness in problem-solving. Furthermore, there was a significant improvement in students' mathematical problem-solving performance, with 82.86% of the students achieving scores above the 70% proficiency threshold. The mean score was 15.43 out of 20 (SD = 2.21). © 2025 IEEE.},
	author_keywords = {Learning Environment; Mathematical Problem Solving; Two-dimensional and Three-dimensional Geometry; Web-based Learning},
	keywords = {Computer aided instruction; Curricula; E-learning; Education computing; Engineering education; Problem solving; Students; Learning environments; Mathematical problem solving; Problem solving skills; Problem-solving; Problem-solving abilities; Three dimensional geometry; Two-dimensional; Two-dimensional and three-dimensional geometry; Web-based learning environment; Web-based-learning; Websites},
	type = {Conference paper},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 0}
}

@ARTICLE{Salido2025188,
	author = {Salido, Achmad and Sugiman and Firdaus, Fery Muhamad and Prihatmojo, Agung and Herwanto, Agus and Andari, Eka Yuni and Wulandari, Widiya Saputri and Rizki, Lussy Midani},
	title = {Uncovering Critical Thinking and Mathematical Representation Skills of Pre-Service Elementary Teachers Through Cognitive Style},
	year = {2025},
	journal = {Qubahan Academic Journal},
	volume = {5},
	number = {2},
	pages = {188 - 203},
	doi = {10.48161/qaj.v5n2a1505},
	url = {https://www.scopus.com/pages/publications/105005632441?origin=resultslist},
	abstract = {This study examines the critical thinking and mathematical representation abilities of pre-service elementary school teachers’ students (PESTS) through the lens of field-dependent (FD) and field-independent (FI) cognitive styles. Using a qualitative descriptive approach, 39 participants completed the Group Embedded Figures Test (GEFT), problem-solving tasks, and semi-structured interviews to assess cognitive styles and representation skills. Results indicate that FD participants struggled with problem-solving, relying on prior experiences, providing superficial solutions, and using primarily symbolic and numerical representations with limited abstraction. In contrast, FI participants demonstrated more assertive critical thinking, systematically employing diverse representations including symbols, mathematical expressions, and verbal explanations to solve problems independently. These differences underscore the need for differentiated instruction, with the FD learners requiring structured support to enhance critical thinking and broaden their representation skills. The FI learners should be challenged with abstract and complex tasks to enhance their skills further. Personalized, adaptive learning strategies are essential to preparing future educators for the challenges of 21st-century teaching. © 2025, Qubahan. All rights reserved.},
	author_keywords = {cognitive style; critical thinking; mathematical representation; mathematics; primary teacher},
	type = {Article},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 1; All Open Access; Gold Open Access; Green Open Access}
}

