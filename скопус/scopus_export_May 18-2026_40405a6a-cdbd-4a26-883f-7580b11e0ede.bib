	doi = {10.1109/AIoT66900.2025.00073},
	url = {https://www.scopus.com/pages/publications/105035767390?origin=resultslist},
	abstract = {The convergence of Artificial Intelligence (AI) and the Internet of Things (IoT), known as AIoT, has transformed numerous sectors, including education. Within STEAM (Science, Technology, Engineering, Arts, and Mathematics) education, AIoT offers novel opportunities for real-time, hands-on learning experiences. However, the inherent complexity of AIoT systems poses substantial challenges for integration into middle and high school curricula, particularly in terms of accessibility, technical knowledge, and instructional design. This paper surveys current practices in leveraging AI tools such as Roboflow, YOLO, and Google Teachable Machine, in combination with prompt engineering techniques, to design effective, engaging lesson plans. Through practical case examples, we explore how educators can utilize AI-generated content to teach complex concepts such as machine learning, IoT sensor integration, and real-time environmental monitoring. The discussion also examines tool-specific limitations, pedagogical considerations, and strategies for future research. Our findings suggest that AI tool adoption, paired with effective prompt engineering, can democratize AI education, foster digital fluency, and promote equitable, interdisciplinary learning in STEAM classrooms.  © 2025 IEEE.},
	author_keywords = {AI tools; AIoT; computer vision; lesson planning; prompt engineering; robotics; STEAM education},
	keywords = {Arts computing; Curricula; E-learning; Education computing; Engineering education; Learning systems; Robotics; Teaching; AIoT; Art educations; Artificial intelligence tools; Lesson planning; Mathematics education; Prompt engineering; Real- time; Science education; Science technologies; Technology education; Computer vision},
	type = {Conference paper},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 0}
}

@CONFERENCE{Nur Patty202567,
	author = {Nur Patty, Naldi Ahmad and Zainuddin, Zahir},
	title = {Comparative Study of PCA-RBFNN and Convolutional-RBFNN Models for Handwritten Mathematical Symbol Recognition in Indonesian Elementary Education},
	year = {2025},
	journal = {Proceedings ICSINTESA 2025 - 2025 5th International Conference of Science and Information Technology in Smart Administration},
	pages = {67 - 72},
	doi = {10.1109/ICSINTESA68165.2025.11413773},
	url = {https://www.scopus.com/pages/publications/105035366228?origin=resultslist},
	abstract = {The integration of artificial intelligence into education has transformed learning evaluation, particularly through automated handwriting recognition in virtual teacher systems. This study presents a comparative study between two hybrid neural network models - Principal Component Analysis Radial Basis Function Neural Network (PCA-RBFNN) and Convolutional Radial Basis Function Neural Network (Conv-RBFNN) - for recognizing handwritten mathematical symbols produced by Indonesian elementary students. A dataset of 1,898 annotated images containing digits (0-9) and basic operators (+, -, ×, ÷, =) was collected and preprocessed using Roboflow with standardized augmentation. The PCA-RBFNN model applies dimensionality reduction to extract compact features, while Conv-RBFNN utilizes convolutional layers to learn spatial hierarchies. Experimental results reveal that Conv-RBFNN achieved superior performance with 95.9% accuracy compared to 50.0% for PCA-RBFNN, demonstrating its robustness in capturing visual variations in children's handwriting. These findings highlight that convolutional feature extraction significantly enhances RBFNN classification accuracy and stability, providing valuable insights for developing intelligent virtual teacher systems in early mathematics education. © 2025 IEEE.},
	author_keywords = {computer vision; Conv-RBFNN; convolutional feature extraction; elementary mathematics education; handwriting recognition; pattern recognition; PCA-RBFNN; radial basis function neural network; virtual teacher system},
	keywords = {Character recognition; Classification (of information); Convolution; Convolutional neural networks; Dimensionality reduction; E-learning; Education computing; Feature extraction; Learning systems; Pattern recognition systems; Teaching; Virtual reality; Convolutional feature extraction; Convolutional radial base function neural network; Elementary mathematic education; Features extraction; Handwriting recognition; Mathematics education; Principal component analysis-radial basis function neural networks; Radial basis function neural networks (RBF); Teachers'; Virtual teacher system; Computer vision; Radial basis function networks},
