	doi = {10.1007/978-3-031-98462-4_39},
	url = {https://www.scopus.com/pages/publications/105012035463?origin=resultslist},
	abstract = {Plotting functions on the Cartesian plane is a critical pedagogical aid for conveying concepts in K-12 mathematics education. We report on the integration of LiveHint AI with the graphing calculator Desmos to generate plots in real-time in response to student messages using LLM function calling. We characterize the system’s behavior, discussing its reliability and readiness for use with students. We also describe recurring issues and discuss possible architectural improvements to mitigate them. Finally, we describe opportunities for future improvements to address issues such as defining appropriate plot bounds and optimizing the frequency at which the tool generates plots. © The Author(s), under exclusive license to Springer Nature Switzerland AG 2025.},
