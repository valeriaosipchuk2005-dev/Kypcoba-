	url = {https://www.scopus.com/pages/publications/105026200144?origin=resultslist},
	abstract = {The integration of Artificial Intelligence (AI) into secondary mathematics education is reshaping traditional teaching and learning. As AI tools become more advanced and accessible, they enhance personalized learning, formative assessment, and adaptive instruction. This chapter highlights how aligning AI with didactic principles, conceptual understanding, procedural fluency, mathematical reasoning, creates responsive and inclusive learning environments. The teacher's role evolves from transmitting knowledge to facilitating deeper understanding, supported by AI-driven insights. While emphasizing the pedagogical benefits, the chapter also examines challenges such as ethics, equity, and technical limitations. Drawing on case studies and evidence, it provides a forward-looking perspective on how AI can transform mathematics education while preserving its core didactic goals. © 2026, IGI Global Scientific Publishing.},
	keywords = {Computer aided instruction; Teaching; Adaptive instruction; Artificial intelligence tools; Conceptual understanding; Formative assessment; Learning environments; Mathematical reasoning; Mathematics education; Personalized learning; Secondary mathematics; Teaching and learning; Artificial intelligence},
	type = {Book chapter},
	publication_stage = {Final},
