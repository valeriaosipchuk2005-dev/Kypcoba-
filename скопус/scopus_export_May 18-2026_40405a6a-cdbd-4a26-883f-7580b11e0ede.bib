@CONFERENCE{Arat2025459,
	author = {Arat, Joshua Gabriel E. and Asuncion, Cecilio M. and Bactol, James Yvan L. and Apdo, Rolly N.},
	title = {Understanding the Academic Progress of Mathematics Education Students Using Structural Equation Modeling},
	year = {2025},
	journal = {2025 IEEE 14th International Conference on Engineering Education: Engineering Education 5.0: Innovation, Intelligence, and Impact, ICEED 2025},
	pages = {459 - 463},
	doi = {10.1109/ICEED66794.2025.11400320},
	url = {https://www.scopus.com/pages/publications/105035998339?origin=resultslist},
	abstract = {This study sought to understand the academic progress of mathematics education students by analyzing the roles of learning behavior, self-efficacy, and support services. It operated within the premise that academic achievement stems not only from intelligence but also from behavioral, psychological, and environmental factors. The research utilized a quantitative approach with Structural Equation Modeling as the primary analysis tool. Data was collected from 240 mathematics education students from Caraga State University using validated survey instruments. The analysis assessed both direct and indirect influences of learning behavior, self-efficacy, and support services on academic progress. Results revealed that support services and classroom climate have a positive and significant direct influence on self-efficacy. Notably, self-efficacy and learning behavior have a positive and significant direct influence on academic progress. Furthermore, self-efficacy positively and significantly mediates the influences of classroom climate and support services on academic progress. These findings underscore the meaningful influence of a good learning environment, strong support systems, learning behavior, and adequate motivation directed towards students bolstering their confidence enhances educational outcomes. © 2025 IEEE.},
	author_keywords = {academic progress; classroom climate; learning behavior; self-efficacy; support services},
