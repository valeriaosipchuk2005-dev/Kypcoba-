	url = {https://www.scopus.com/pages/publications/105024625069?origin=resultslist},
	abstract = {Mathematical thinking has a crucial role in STEM education. It encompasses problemsolving, logical reasoning, pattern recognition, abstraction, among others, that are transversal to many technical areas. Incorporating the capabilities of Artificial Intelligence into math education can enhance learning efficiency while providing personalized instruction. It also allows us to simulate complex or rare situations, which enrich the preparation of students. However, the use of these tools also raises ethical concerns, such as data privacy, or algorithmic bias. In addition, potential over-reliance on AI has raised concerns about weakening critical thinking and to the amplification of injustice, issues that may widen educational gaps. Integration strategies, where a balanced approach with human oversight must be implemented, inclusive technology design, and careful monitoring of educational outcomes are crucial to responsibly use AI. This way, ethical standards in mathematics education for engineering disciplines can be upheld. © 2026 by IGI Global Scientific Publishing. All rights reserved.},
	keywords = {Artificial intelligence; Data privacy; Ethical technology; Pattern recognition; STEM (science, technology, engineering and mathematics); Algorithmics; Enhance learning; Ethical concerns; Learning efficiency; Logical reasoning; Mathematical thinking; Over reliance; Personalized instruction; Reasoning patterns; STEM education; Engineering education},
	type = {Book chapter},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 0}
}

