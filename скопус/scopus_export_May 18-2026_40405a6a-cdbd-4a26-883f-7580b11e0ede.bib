@CONFERENCE{Zhang2025844,
	author = {Zhang, Shi-Yu and Fu, Xinliang and Fu, Peien and Chang, Yi-Lin},
	title = {The TASP Instructional Design Model: Embedding AI Literacy in K-12 STEAM},
	year = {2025},
	journal = {8th International Conference on Educational Technology Management, ICETM 2025},
	pages = {844 - 848},
	doi = {10.1109/ICETM67477.2025.11413493},
	url = {https://www.scopus.com/pages/publications/105035368303?origin=resultslist},
	abstract = {The rapid advancement of Artificial Intelligence (AI) underscores the necessity of cultivating AI literacy as a foundational competency for 21st-century learners. Yet, standardized and integrable frameworks for embedding AI education into K-12 curricula remain underdeveloped. This paper addresses this gap by proposing a synergistic integration of AI literacy and STEAM (Science, Technology, Engineering, Arts, and Mathematics) education. We argue that established frameworks such as the Next Generation Science Standards (NGSS) offer a robust foundation for AI education. For example, the NGSS practice of Analyzing and Interpreting Data directly parallels the Data Literacy dimension of AI literacy. Building upon these theoretical linkages, we introduce the TASP (TaskGuided, AI-Supported, Self-Paced, Project-Based) instructional design model as the central contribution of this study. The TASP model provides a structured yet adaptable methodology for designing learning experiences in which students leverage AI tools to solve authentic, project-based problems. By positioning AI literacy not as a standalone subject but as an enhancement to the inquiry-driven ethos of STEAM, the model offers a scalable pathway for curriculum innovation. This conceptual framework contributes to the field of educational technology management by offering a theoretically grounded and practically applicable approach to systematically embedding AI literacy within K-12 education. © 2025 IEEE.},
	author_keywords = {AI Literacy; Instructional Design; Next Generation Science Standards (NGSS); STEAM Education},
	keywords = {Artificial intelligence; Design; Education computing; Educational technology; Embeddings; Engineering education; Information management; Art educations; Artificial intelligence literacy; Instructional designs; Mathematics education; Next generation science standard; Project-based; Science education; Science standards; Science technologies; Technology education; Curricula},
	type = {Conference paper},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 0}
}

@CONFERENCE{Ferdiánová2025113,
	author = {Ferdiánová, Věra and Konečná, Petra},
	title = {Understanding and Supporting Student Problem Solving in Mathematics Exams with Artificial Intelligence},
	year = {2025},
	journal = {Proceedings of the European Conference on e-Learning, ECEL},
	pages = {113 - 121},
	doi = {10.34190/ecel.24.1.3925},
	url = {https://www.scopus.com/pages/publications/105030147414?origin=resultslist},
	abstract = {This paper presents the findings of a pilot study aimed at gaining deeper insights into student errors in solving mathematics tasks from the Czech national school-leaving examination (maturita), while also exploring the potential of artificial intelligence (AI) to support error analysis and provide targeted feedback. The study began with an analysis of publicly available CERMAT data, focusing on tasks that have consistently shown low success rates over the years. Based on this analysis, a subset of tasks was selected and further tested on students preparing for the exam. The results were compared with national statistics to validate the relevance of the identified difficulties. A revised version of the test was then developed and administered to a new cohort of students, enabling the collection of a dataset of real student solutions for qualitative error analysis. The study adopted a nuanced framework for error classification, distinguishing between “slips” (minor, often procedural errors) and “true errors” stemming from a lack of conceptual understanding. Emphasis was placed on understanding the nature and origin of these errors, their recurrence, and implications for learning. Student work was analysed in all phases of the error-handling process, including detection, diagnosis, explanation, and correction. At the same time, the study evaluated selected AI tools, primarily ChatGPT 4.0-for their potential to solve exam-level mathematics tasks at the university level and identify errors in student solutions. Multiple test items were processed through the AI system, and its responses were compared with those of students. Particular attention was given to the AI's behaviour when confronted with incorrect or incomplete answers. The results revealed both the promise and limitations of current AI models in supporting formative assessment, particularly with respect to misinterpretation of task wording, difficulty in recognising alternative valid strategies, and occasional inconsistency in the quality of feedback. The findings contribute to the broader discussion on how AI can be effectively integrated into educational practice-not as a replacement for teacher judgment, but as a supplementary tool to enhance student understanding, develop metacognitive skills, and improve preparation for high-stakes assessments such as the maturita exam. © 2025 Academic Conferences Limited. All rights reserved.},
	author_keywords = {Artificial Intelligence in Education; Conceptual Understanding; Diagnostic Feedback; Educational Technology; Error Analysis; Mathematics Education; National high-stakes assessment; Secondary Education; Student Misconceptions; Test Validation},
	keywords = {Education computing; Educational technology; Engineering education; Error detection; Feedback; Problem solving; Quality control; Statistical tests; Students; Teaching; Artificial intelligence in education; Conceptual understanding; Diagnostic feedback; Mathematics education; National high-stake assessment; Pilot studies; Problem-solving; Secondary education; Student misconceptions; Test validation; Error analysis},
	type = {Conference paper},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 0; All Open Access; Gold Open Access}
}

@CONFERENCE{Feijoo-Garcia2025472,
	author = {Feijoo-Garcia, Miguel A. and Zhang, Yiqun and Gu, Yiyin and Magana, Alejandra J. and Benes, Bedrich and Popescu, Voicu},
	title = {Exploring Extended Reality (XR) in Teaching AI: A Comparative Study of XR and Desktop Environments},
	year = {2025},
	journal = {Proceedings of the International Joint Conference on Computer Vision, Imaging and Computer Graphics Theory and Applications},
	volume = {1},
	pages = {472 - 482},
	doi = {10.5220/0013141000003912},
	url = {https://www.scopus.com/pages/publications/105001990229?origin=resultslist},
	abstract = {Artificial Intelligence (AI) concepts are abstract and difficult to understand. This paper explores how immersive technologies, such as extended reality (XR), can offer interactive learning experiences that can significantly enhance the educational outcomes of teaching fundamental concepts in artificial intelligence. This comparative study analyzes the effectiveness of an XR environment for introducing Neural Networks and Handwritten Digit Recognition by comparing the engagement, user experience, and learning outcomes of students using XR headsets (Meta Quest 3) to those relying on a traditional desktop setup. Engagement, usability, and user satisfaction were measured using standardized metrics, including the System Usability Scale (SUS), Immersion Presence Questionnaire (IPQ), User Satisfaction Questionnaire (USQ), and Net Promoter Score (NPS), on a diverse group of 56 participants. The findings indicate that the participants in the XR group reported higher levels of engagement and immersion than those in the desktop setting. Furthermore, they reported higher levels of satisfaction. They were more likely to recommend the experience for educational reasons compared to the users of the Desktop group, suggesting that XR technology increases motivation and may thus improve learning. Nevertheless, XR users recognized restrictions like unease or lack of familiarity with immersive technologies. In addition, this study highlights how XR can help transform science, technology, engineering, and mathematics education. © 2025 by SCITEPRESS–Science and Technology Publications, Lda.},
	author_keywords = {Educational Technology; Extended Reality; Human-Computer Interaction; Immersive Learning; User Experience},
	type = {Conference paper},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 3; All Open Access; Gold Open Access}
}

@BOOK{Evkaya202559,
	author = {Evkaya, Ozan and Genc, Ozhan},
	title = {Gen-AI use cases for mathematics education: Experiments and discussions},
	year = {2025},
	journal = {Generative Artificial Intelligence Applications: Holistic Reflections From The Educational Landscape},
	pages = {59 - 90},
	url = {https://www.scopus.com/pages/publications/86000452291?origin=resultslist},
	abstract = {In the last couple of decades, Artificial Intelligence (AI) has significantly impacted many industries, including higher education. More recently, this impact is accelerating with the rise of the immense potential of Generative AI (Gen-AI), equivalently Large Language Models (LLMs). This study aims to explore the potential capabilities and certain limitations of the Gen-AI tools in mathematics higher education and their impact on teaching. Specifically, the goal is to investigate how to use Gen-AI tools, namely different ChatGPTs for learning efficiently and in a secure way for a common mathematics course at universities. For this purpose, both the default versions (ChatGPT 3.5 and ChatGPT 4) and customised ChatGPT 4-based models are considered for the Year 1 Mathematics Calculus course. For that purpose, carefully curated questions covering different topics are considered to investigate the performance of the above-mentioned tools. The experimental findings are discussed in detail by highlighting the pros and cons of such advanced technologies in the educational landscape. Additionally, specific suggestions are discussed for the safe use of such tools without distracting students' learning processes. Relying on these course-specific findings, the underlined potential advantages or challenges of LLMs are aimed at being useful for their appropriate use in higher education. © 2024 Peter Lang Group AG, Lausanne.},
	author_keywords = {Custom GPT; Generative AI (Gen-AI); Large language models (LLMs); Mathematics education (ME)},
	type = {Book chapter},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 0}
}

