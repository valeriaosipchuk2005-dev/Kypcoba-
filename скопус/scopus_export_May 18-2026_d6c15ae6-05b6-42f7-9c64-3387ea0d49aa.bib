@BOOK{Ulusoy2025187,
	author = {Ulusoy, Fadime},
	title = {Prospective Teachers’ Perceived Affordances and Constraints of Using ChatGPT in Mathematical Problem Posing},
	year = {2025},
	journal = {The Convergence of Mathematics and AI: A New Paradigm in Education},
	pages = {187 - 225},
	doi = {10.4018/979-8-3373-1998-8.ch007},
	url = {https://www.scopus.com/pages/publications/105024652604?origin=resultslist},
	abstract = {This qualitative study explores prospective mathematics teachers’ (PMTs) perceived affordances and constraints of using ChatGPT in mathematical problem posing. Data were collected from 23 PMTs through reflection papers, which documented their experiences using ChatGPT to pose real-life mathematical problems with varying cognitive demand levels. The study employed qualitative content analysis using both deductive and inductive approaches to examine PMTs’ experiences with ChatGPT. The findings reveal that PMTs value ChatGPT for its immediate feedback, contextual diversity, and ability to provide personalized learning paths. Additionally, PMTs highlighted its potential as an assessment tool for evaluating the quality of posed problems. However, significant constraints were also identified, such as ChatGPT’s limited ability to generate diverse and novel problems, difficulties in producing realistic and contextually rich problems, and mathematical inaccuracies. Additionally, PMTs noted ChatGPT’s poor visualization and complex language use, particularly in higher cognitive demand tasks. © 2026 by IGI Global Scientific Publishing. All rights reserved.},
	keywords = {Teaching; Cognitive demands; Content analysis; Immediate feedbacks; Mathematical problems; Mathematics teacher; Perceived affordances; Personalized learning; Prospectives; Qualitative study; Teachers'; Reflection},
	type = {Book chapter},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 0}
}

@BOOK{Evkaya202559,
	author = {Evkaya, Ozan and Genc, Ozhan},
	title = {Gen-AI use cases for mathematics education: Experiments and discussions},
	year = {2025},
	journal = {Generative Artificial Intelligence Applications: Holistic Reflections From The Educational Landscape},
	pages = {59 - 90},
	url = {https://www.scopus.com/pages/publications/86000452291?origin=resultslist},
	abstract = {In the last couple of decades, Artificial Intelligence (AI) has significantly impacted many industries, including higher education. More recently, this impact is accelerating with the rise of the immense potential of Generative AI (Gen-AI), equivalently Large Language Models (LLMs). This study aims to explore the potential capabilities and certain limitations of the Gen-AI tools in mathematics higher education and their impact on teaching. Specifically, the goal is to investigate how to use Gen-AI tools, namely different ChatGPTs for learning efficiently and in a secure way for a common mathematics course at universities. For this purpose, both the default versions (ChatGPT 3.5 and ChatGPT 4) and customised ChatGPT 4-based models are considered for the Year 1 Mathematics Calculus course. For that purpose, carefully curated questions covering different topics are considered to investigate the performance of the above-mentioned tools. The experimental findings are discussed in detail by highlighting the pros and cons of such advanced technologies in the educational landscape. Additionally, specific suggestions are discussed for the safe use of such tools without distracting students' learning processes. Relying on these course-specific findings, the underlined potential advantages or challenges of LLMs are aimed at being useful for their appropriate use in higher education. © 2024 Peter Lang Group AG, Lausanne.},
	author_keywords = {Custom GPT; Generative AI (Gen-AI); Large language models (LLMs); Mathematics education (ME)},
	type = {Book chapter},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 0}
}

@ARTICLE{Au2025,
	author = {Au, Cheuk Kwan and Yoo, Soyoo and Chiu, Thomas K. F.},
	title = {Student Engagement and Teacher Perceived Support in STEAM Education Using Generative AI: A Systematic Review and Direction for Future Research},
	year = {2025},
	journal = {School Science and Mathematics},
	pages = {},
	doi = {10.1111/ssm.18413},
	url = {https://www.scopus.com/pages/publications/105020473361?origin=resultslist},
	abstract = {The emergence of generative AI (GenAI), such as ChatGPT, in education reconceptualizes the realm and is novel to researchers and practitioners alike. Over the past few years, systematic reviews of the impact of GenAI on education have increased, focusing on language education and general education. Such reviews may overlook other integrated disciplines. This impact can be reflected in student engagement (learning outcomes) and teacher perspectives. In response, this review aims to investigate the impact of integrating GenAI on student engagement and teacher-perceived support in science, technology, engineering, art, and mathematics (STEAM) education. It used a thematic analysis approach to examine relevant articles published over the past 5 years (2020–2024). The findings suggest 11 constructs on how GenAI tools affect the development of student cognitive, behavioral, and emotional engagement. They also suggest three themes about how STEAM teachers felt about GenAI tools—attitude, pedagogy, and 21st-century skills. We used the findings to suggest recommendations for future directions of GenAI research. © 2025 The Author(s). School Science and Mathematics published by Wiley Periodicals LLC on behalf of School Science and Mathematics Association.},
	author_keywords = {artificial intelligence; pedagogy; STEAM education; student engagement; teacher education},
	type = {Article},
	publication_stage = {Article in press},
	source = {Scopus},
	note = {Cited by: 1; All Open Access; Hybrid Gold Open Access}
}

