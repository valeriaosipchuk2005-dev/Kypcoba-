	keywords = {Educational robots; Ethical technology; Students; Teaching; ChatGPT; Educational context; Educational levels; Generative pre-trained transformer; High educations; Personalized learning; STEM education; Systematic literature review; Teaching efficiencies; Teaching quality; STEM (science, technology, engineering and mathematics)},
