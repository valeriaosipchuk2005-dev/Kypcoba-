	doi = {10.4018/979-8-3373-1998-8.ch004},
	url = {https://www.scopus.com/pages/publications/105024655074?origin=resultslist},
	abstract = {Artificial intelligence (AI) is transforming preschool mathematics education by offering personalized learning experiences, adaptive teaching strategies, and interactive content delivery. AI tools like ChatGPT provide individualized feedback, enabling students to engage dynamically with mathematical concepts while supporting educators in lesson planning and content development, but at the same time AI integration raises ethical and technological concerns, including data privacy risks, screen exposure management, and technological accessibility limitations in underresourced schools. Addressing disparities in AI access necessitates policy-driven solutions that prioritize digital equity and teacher preparedness. AI should enhance, not replace human-led teaching, ensuring responsible implementation. This study concludes that structured AI adoption in preschool mathematics can significantly improve learning outcomes, provided that ethical, infrastructural, and pedagogical challenges are effectively managed. © 2026 by IGI Global Scientific Publishing. All rights reserved.},
	keywords = {Artificial intelligence; Ethical technology; Information management; Teaching; Artificial intelligence tools; Contents deliveries; Contents development; Interactive contents; Learning experiences; Mathematical concepts; Mathematics education; Personalized learning; Teachers' perceptions; Teaching strategy; Data privacy},
	type = {Book chapter},
	publication_stage = {Final},
