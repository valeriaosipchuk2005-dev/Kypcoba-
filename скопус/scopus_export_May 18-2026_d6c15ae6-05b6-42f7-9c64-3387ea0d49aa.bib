@ARTICLE{Ji2025402,
	author = {Ji, Yu and Zhan, Zehui and Li, Tingting and Zou, Xuanxuan and Lyu, Siyuan},
	title = {Human-Machine Cocreation: The Effects of ChatGPT on Students' Learning Performance, AI Awareness, Critical Thinking, and Cognitive Load in a STEM Course Toward Entrepreneurship},
	year = {2025},
