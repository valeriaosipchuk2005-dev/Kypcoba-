	title = {Generative Artificial Intelligence in STEM Education: A Review of Applications, Benefits and Challenges},
	year = {2026},
	journal = {Expert Systems},
	volume = {43},
	number = {2},
	pages = {},
	doi = {10.1111/exsy.70201},
	url = {https://www.scopus.com/pages/publications/105027185584?origin=resultslist},
	abstract = {Generative artificial intelligence (GAI) has emerged as a transformative force in STEM education, offering new possibilities for personalised instruction, content creation and interactive learning. This review examines the current landscape of GAI applications in science, technology, engineering and mathematics, highlighting key tools such as GPT-4, DALL (Formula presented.) E, AlphaCode and CodeGen. The paper synthesises recent research and practices to identify the pedagogical benefits of GAI, including enhanced self-paced learning, improved access to resources and support for interdisciplinary instruction. It also addresses critical challenges, such as the reliability of generated content, ethical concerns, data privacy and teacher preparedness. These challenges were identified through a synthesis of recent empirical studies, policy reports and expert commentaries in the field of GAI in education, which consistently highlight these issues as major barriers to effective implementation. Based on these findings, the review describes implications for curriculum integration, professional development and institutional policy. Furthermore, the study situates GAI within a broader historical and theoretical context, tracking its evolution from traditional machine learning and deep learning approaches and aligning its educational applications with constructivist, cognitive load and personalised learning theories. By categorising specific use cases across STEM disciplines, such as automated scientific explanations, AI-generated visualisations, intelligent tutoring systems (ITS), virtual engineering labs and adaptive math assessments, the review illustrates the diverse and practical utility of GAI in classroom and remote learning environments. These cases were selected to represent a cross-section of the core instructional needs in STEM education: explanation, visualisation, guidance, experimentation and assessment, where GAI offers distinct functional advantages. They were categorised according to the primary instructional role they fulfil, allowing a pedagogically meaningful organisation of GAI capabilities aligned with common learning processes in STEM. The analysis also emphasises the importance of teacher agency, student participation and equitable access in shaping effective GAI adoption. Finally, this review identifies key future research directions, including the need for longitudinal studies on learning outcomes, efforts to improve the transparency and explainability of GAI models in educational contexts, the development of domain-specific generative tools tailored to STEM subfields, and the exploration of collaborative human–AI learning environments. © 2026 John Wiley & Sons Ltd.},
	author_keywords = {AI tutoring; educational technology; GAI; personalised learning; STEM education},
	keywords = {Collaborative learning; Computer aided instruction; Curricula; Data privacy; Deep learning; E-learning; Education computing; Engineering education; Laboratories; Learning systems; STEM (science, technology, engineering and mathematics); Students; Teaching; Virtual reality; Visualization; AI tutoring; Benefit and challenges; Content creation; Generative artificial intelligence; Interactive learning; Learning environments; Personalized instruction; Personalized learning; STEM education; Teachers'; Educational technology},
	type = {Article},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 0}
}

@BOOK{Gunduz202633,
	author = {Gunduz, Abdullah Yasin},
	title = {AI Risk Assessment Framework for Teachers},
	year = {2026},
	journal = {Human-AI Collaboration and the Evolving Role of Educators},
	pages = {33 - 56},
	doi = {10.4018/979-8-3373-4521-5.ch002},
	url = {https://www.scopus.com/pages/publications/105035270639?origin=resultslist},
	abstract = {The rapid adoption of artificial intelligence tools in education has outpaced system-atic risk assessment development. Teachers lack practical frameworks to evaluate potential harms in classroom applications. While UNESCO, OECD, the EU AI Act, and NIST provide institutional guidelines, these remain inadequately operationalized for individual teaching practice. Through comparative analysis of international standards, a teacher-centered risk assessment framework is developed. Regulatory requirements are translated into a four-step methodology comprising inventory creation, risk prioritization, mitigation strategies, and monitoring. Implementation barriers are identified, including time constraints, digital literacy gaps, legal uncer-tainties, and institutional resistance. The framework demonstrates how teachers can systematically evaluate Al tools while maintaining professional autonomy within institutional policy contexts. This study establishes a bridge between high-level governance frameworks and classroom-level decision-making, offering actionable guidance for teachers. © 2026 by IGI Global Scientific Publishing. All rights reserved.},
	keywords = {Artificial intelligence; Decision making; International cooperation; Teaching; Artificial intelligence tools; Assessment development; Comparative analyzes; International standards; Potential harm; Regulatory requirements; Risk assessment framework; Risks assessments; Teachers'; Teaching practices; Risk assessment},
	type = {Book chapter},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 0}
}

