	url = {https://www.scopus.com/pages/publications/105024161528?origin=resultslist},
	abstract = {This chapter discusses how eXplainable artificial intelligence (XAI) in education research aims to improve the trust and transparency of black box algorithms and can address the data ethics needs established by formal regulatory measures, such as the European Union's General Data Protection Regulation (GDPR) and Artificial Intelligence Act (AI Act), regulations applicable in the EU. We frame the discussion within the broader themes of recent efforts in XAI in education research, such as enhancing model prediction interpretability and fostering trust in AI, and how these characteristics align with the needs of education stakeholders, including students, teachers, and guardians. Understanding initiatives to make AI systems more explainable takes on an even greater importance when considering early childhood students, who may rely on guardians and educators to advocate for the collection and safe use of their data. This chapter identifies the motivations behind government data regulations such as the GDPR and AI Act, and how XAI can help to not only enhance learning for students but also support the trust and ethical needs defined by formal data regulations. © 2026 John Wiley & Sons, Inc. Published 2026 by John Wiley & Sons, Inc.},
	keywords = {Artificial intelligence; Education computing; Ethical aspects; Laws and legislation; Teaching; AI systems; Black box algorithms; Data regulations; Early childhoods; Education research; European union; General data protection regulations; Interpretability; Model prediction; Student teachers; Students},
	type = {Book chapter},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 1}
}

