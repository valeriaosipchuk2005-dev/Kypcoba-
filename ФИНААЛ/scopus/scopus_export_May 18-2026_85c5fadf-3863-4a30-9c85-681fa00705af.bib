@ARTICLE{Caruana2026,
	author = {Caruana, Inmaculada and Gilar-Corbi, Raquel and Palomar, Manuel},
	title = {Bridging the AI Skills Gap for Sustainable Education: A Structural Model of In-Service Teachers’ Learning Intentions and Behaviors},
	year = {2026},
	journal = {Sustainability (Switzerland)},
	volume = {18},
	number = {6},
	pages = {},
	doi = {10.3390/su18063133},
	url = {https://www.scopus.com/pages/publications/105034311711?origin=resultslist},
	abstract = {As artificial intelligence (AI) drives significant challenges in education, understanding and addressing the training needs of in-service teachers has become a critical issue for ensuring a responsible and long-term technological transition. Framed within Sustainable Development Goal 4 (SDG 4) and the principles of Education for Sustainable Development (ESD), teacher preparation in AI is increasingly recognized as a key mechanism for promoting ethical, equitable, and inclusive educational transformation. This study explores the influence of several key variables on intention and learning behaviors in relation to AI among a sample of 704 Spanish in-service teachers (71% women) from all compulsory educational levels. Using a validated questionnaire, this study assessed teachers’ anxiety towards AI, basic AI knowledge, personal relevance of AI, AI for social good, perceived self-efficacy, social pressure, and perceived usefulness of AI. Structural equation modeling (SEM) was employed to analyze the direct and indirect relationships among these variables. The results indicate that the perceived usefulness of AI and self-efficacy directly and positively influence the behavioral intention to learn about AI. Furthermore, social pressure and basic AI knowledge indirectly influence this intention. In turn, both behavioral intention and social pressure significantly predicted AI learning behaviors. The model demonstrates strong explanatory power, accounting for 91% of the variance in the behavioral intention to learn about AI. These findings provide evidence to inform the design of teacher training initiatives and policies that promote responsible, ethical, and inclusive integration of AI in educational settings, contributing to sustainable development through education. © 2026 by the authors.},
	author_keywords = {artificial intelligence; in-service teachers; structural equation analysis; sustainable education; teacher development},
	keywords = {artificial intelligence; education policy; educational attainment; educational development; learning; statistical analysis; sustainable development; teacher training; teaching},
	type = {Article},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 1; All Open Access; Gold Open Access}
}

@BOOK{Fortiș2026173,
	author = {Fortiș, Alexandra-Emilia and Gaudo, Maria Villarroya and Fazendeiro, Paulo and Exposito, Ernesto and Pedro, Nkanga},
	title = {Inclusive Education with AI: Supporting Special Needs and Overcoming Language Barriers},
	year = {2026},
	journal = {AI in Early Education: Integrating Artificial Intelligence for Inclusive and Effective Learning},
	pages = {173 - 200},
	doi = {10.1002/9781394352821.ch11},
	url = {https://www.scopus.com/pages/publications/105024164039?origin=resultslist},
	abstract = {This chapter presents a collaborative effort within the UNITA university alliance to design a joint curriculum for a teacher training program dedicated to integrating artificial intelligence (AI), machine learning (ML), Computational Thinking, and Visual Programming in preuniversity education. The authors detail the process of developing and using extensive, easily accessible, open, and inclusive informal and nonformal educational contexts, aimed at covering the entire preuniversity age range and preparing children for success in digital, high-tech, STEAM-based professions. Drawing on insights from recent PISA and Eurydice reports, the chapter highlights the urgent need for intervention to address gaps and challenges faced by educational systems across Europe (Bozkurt et al., 2024). In response to the existing gender gap in digital disciplines, an Erasmus+ Blended Intensive Program has been codesigned, emphasizing the importance of incorporating a gender perspective when teaching STEAM subjects and training young children in digital skills. The program aims to equip preservice teachers with targeted training to facilitate the introduction of STEAM topics with the support of AI. The chapter outlines key goals, including fostering discussions on AI bias, introducing AI in primary and secondary schools, and promoting critical thinking in AI usage. It also analyzes various visual programming applications that can help beginners understand foundational AI concepts, while mapping experiences from higher education in AI to inform the development of new educational materials and lifelong learning programs for both preservice and in-service teachers. © 2026 John Wiley & Sons, Inc. Published 2026 by John Wiley & Sons, Inc.},
	keywords = {Application programs; Artificial intelligence; Collaborative learning; Curricula; Learning systems; Teaching; Computational thinkings; Educational context; Educational systems; High tech; Inclusive education; Language barriers; Machine-learning; Special needs; Teachers training programs; Visual programming; Personnel training},
