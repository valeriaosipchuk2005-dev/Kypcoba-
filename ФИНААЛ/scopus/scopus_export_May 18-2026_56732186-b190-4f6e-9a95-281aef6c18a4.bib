	year = {2025},
	journal = {Proceedings - 2025 10th International STEM Education Conference, iSTEM-Ed 2025},
	pages = {},
	doi = {10.1109/iSTEM-Ed65612.2025.11129360},
	url = {https://www.scopus.com/pages/publications/105015886151?origin=resultslist},
	abstract = {Developing structured problem-solving skills is essential in engineering education, especially in thermodynamics, a foundational yet conceptually challenging course. This paper presents a five-step framework that guides students through identifying knowns and unknowns, constructing schematics, defining control volumes, applying models, and conducting analysis. The method emphasizes logical reasoning, unit consistency, and conceptual clarity, distinguishing it from traditional plug-and-chug approaches. Two instructional practices support this framework: (1) a rubric-aligned grading policy applied consistently across assessments, and (2) targeted scaffolding of difficult steps, particularly schematics and symbolic modeling. Although students initially express concern about the method's time demands, feedback suggests increased clarity, confidence, and deeper understanding over time. Implementation challenges such as cognitive overload and resistance to process-heavy methods are addressed through in-class modeling and collaborative activities. Future work includes integrating digital tools, like interactive simulations and automated feedback systems, to further enhance engagement and structured reasoning. These strategies offer transferable insights for promoting analytical thinking across STEM disciplines.  © 2025 IEEE.},
	author_keywords = {Critical Thinking Development; Engineering Education; STEM Pedagogy; Structured Problem-Solving; Thermodynamics Instruction},
	keywords = {Curricula; Digital devices; Education computing; Feedback; Grading; Problem solving; STEM (science, technology, engineering and mathematics); Students; Teaching; Thermodynamics; Control volumes; Critical thinking; Critical thinking development; Logical reasoning; Problem solving skills; Problem-solving; STEM pedagogy; Structured problem-solving; Structured problems; Thermodynamic instruction; Engineering education},
	type = {Conference paper},
