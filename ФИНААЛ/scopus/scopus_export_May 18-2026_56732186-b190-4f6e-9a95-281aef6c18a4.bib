@CONFERENCE{Bhatia201860,
	author = {Bhatia, Sahil and Kohli, Pushmeet and Singh, Rishabh},
	title = {Neuro-Symbolic Program Corrector for Introductory Programming Assignments},
	year = {2018},
	journal = {Proceedings - International Conference on Software Engineering},
	volume = {2018-January},
	pages = {60 - 70},
	doi = {10.1145/3180155.3180219},
	url = {https://www.scopus.com/pages/publications/85107705203?origin=resultslist},
	abstract = {Automatic correction of programs is a challenging problem with numerous real world applications in security, verification, and education. One application that is becoming increasingly important is the correction of student submissions in online courses for providing feedback. Most existing program repair techniques analyze Abstract Syntax Trees (ASTs) of programs, which are unfortunately unavailable for programs with syntax errors. In this paper, we propose a novel Neuro-symbolic approach that combines neural networks with constraint-based reasoning. Specifically, our method first uses a Recurrent Neural Network (RNN) to perform syntax repairs for the buggy programs; subsequently, the resulting syntactically-fixed programs are repaired using constraint-based techniques to ensure functional correctness. The RNNs are trained using a corpus of syntactically correct submissions for a given programming assignment, and are then queried to fix syntax errors in an incorrect programming submission by replacing or inserting the predicted tokens at the error location. We evaluate our technique on a dataset comprising of over 14,500 student submissions with syntax errors. Our method is able to repair syntax errors in 60% (8689) of submissions, and finds functionally correct repairs for 23.8% (3455) submissions. © 2018 IEEE Computer Society. All rights reserved.},
	author_keywords = {Automated Feedback Generation; Neural guided search; Neural Program Correction},
	keywords = {Application programs; Errors; Recurrent neural networks; Students; Syntactics; Trees (mathematics); Automated feedback; Automated feedback generation; Automatic corrections; Guided search; Introductory programming; Neural guided search; Neural program correction; Program correction; Programming assignments; Syntax errors; Repair},
	type = {Conference paper},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 79}
}

@ARTICLE{Yaghmour202570,
	author = {Yaghmour, Samer and Qureshi, Muhammad Imran and Ullah, Ihtisham and Perumal, Ravindra Kumar and Khan, Muhammad Muddassar},
	title = {AI-Driven Adaptive Learning Systems in Mobile Education: A Systematic Review of Personalization Strategies, Effectiveness, and User Interaction},
	year = {2025},
	journal = {International Journal of Interactive Mobile Technologies },
	volume = {19},
	number = {19},
	pages = {70 - 86},
	doi = {10.3991/ijim.v19i19.57695},
	url = {https://www.scopus.com/pages/publications/105019242286?origin=resultslist},
	abstract = {While artificial intelligence (AI) has transformed educational contexts through automated feedback generation, critical fragmentation exists in understanding its sustained impact on student learning trajectories, particularly regarding emotion recognition technologies in mobile STEM education. This systematic review investigates AI-driven adaptive learning systems in mobile education, examining personalization strategies, effectiveness measures, and user interaction patterns to establish foundations for emotion-aware educational technologies. A systematic literature review following PRISMA guidelines was conducted across major academic databases, yielding 39 eligible studies from 2015–2025. Bibliometric analysis using R Studio’s bibliometric package examined research patterns, collaboration networks, and thematic evolution. Network analysis of key term co-occurrences and cluster analysis identified conceptual relationships and structural hierarchies within the research domain. The field demonstrates exponential growth with a 32.75% annual increase in research output, particularly since 2022. Mobile learning emerged as the dominant conceptual hub (betweenness centrality: 197.446), with AI and personalized learning serving as critical connectors between research domains. Three primary themes were identified: personalization strategies establishing sophisticated frameworks for learner modeling and context-aware adaptation; effectiveness measures revealing consistent improvements in academic performance and engagement across STEM contexts; and user interaction patterns exposing both transformative potential and challenges concerning data privacy and usability considerations. This study provides the first comprehensive systematic mapping of AI-driven mobile learning through the lens of emotion recognition potential, revealing substantial gaps in longitudinal impact assessment and theoretical integration. Findings advance understanding of how the Adaptive Feedback Regulation Framework can be enhanced through emotion-aware technologies, offering practical insights for implementing sophisticated personalization strategies. Future research should prioritize longitudinal studies examining sustained impact, crosscultural acceptance patterns, and ethical implications of emotion recognition in educational contexts. © 2025 by the authors of this article. Published under CC-BY.},
	author_keywords = {adaptive learning systems; artificial intelligence (AI); mobile education; personalization strategies; systematic review; user interaction design},
	keywords = {Artificial intelligence; Data privacy; E-learning; Education computing; Educational technology; Engineering education; Feedback; Learning systems; Psychology computing; STEM (science, technology, engineering and mathematics); User interfaces; Adaptive learning systems; Artificial intelligence; Educational context; Effectiveness measure; Emotion recognition; Mobile educations; Personalization strategies; Systematic Review; User interaction; User interaction design; Emotion Recognition},
	type = {Article},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 0; All Open Access; Gold Open Access; Green Open Access}
}

@CONFERENCE{Thampitak2025,
	author = {Thampitak, Duanpen and Junpeng, Putcharee},
	title = {Developing the Structure of Observed Learning Outcomes in the Measurement and Geometry Strand for Grade 8thGifted Students through Intelligence Tutoring Systems Khon Kaen Wittayayon School Thailand},
	year = {2025},
	journal = {2025 International Technical Conference on Circuits/Systems, Computers, and Communications, ITC-CSCC 2025},
	pages = {},
	doi = {10.1109/ITC-CSCC66376.2025.11137645},
	url = {https://www.scopus.com/pages/publications/105016388571?origin=resultslist},
	abstract = {This study assessed and compared the learning progression in mathematical and conceptual understanding within the domain of Measurement and Geometry (SLO - Structure of Learning Outcomes) among Grade 8th students using an Intelligent Tutoring System. Conducted at Khon Kaen Wittayayon School in the 2024 academic year, the study involved 62 students, divided equally into experimental and control groups. The experimental group utilized a digital platform that integrated diagnostic assessments with intelligent feedback, adapting instruction to individual needs. The control group used the same system but without automated feedback. Results showed that the experimental group's average pre-test score was 1.39 (SD = 0.72), with the post-test increasing to 3.58 (SD = 0.81). The control group's average pre-test score was 1.19 (SD = 0.60), with the post-test rising to 3.09 (SD = 0.98). Learning progression, measured by relative gain scores, averaged 86.29% (SD = 26.75) for the experimental group classified as very high while the control group scored 69.89% (SD = 32.61), indicating high development. Although both groups progressed, the experimental group achieved significantly more significant gains. These findings highlight the effectiveness of the Intelligent Tutoring System with diagnostic and adaptive feedback in enhancing students' mathematical and conceptual understanding by providing personalized, responsive learning experiences. © 2025 IEEE.},
