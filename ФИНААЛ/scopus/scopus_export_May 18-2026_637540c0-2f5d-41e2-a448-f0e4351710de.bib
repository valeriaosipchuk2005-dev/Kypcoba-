	title = {Development of an Adaptive Learning Application Using Machine Learning for Didactic Transposition in Algebra},
	year = {2025},
	journal = {Proceedings - 7th International Conference on Informatics, Multimedia, Cyber and Information System, ICIMCIS 2025},
	pages = {1 - 7},
