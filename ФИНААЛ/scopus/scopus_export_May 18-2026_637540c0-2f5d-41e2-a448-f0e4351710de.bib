@CONFERENCE{Russo2025281,
	author = {Russo, Francesca and Calò, Tommaso and De Russis, Luigi},
	title = {Towards Step-Aware ITSs: Generation and Evaluation of Synthetic Step-by-Step Exercise Solutions},
	year = {2025},
	journal = {L@S 2025 - Proceedings of the 12th ACM Conference on Learning @ Scale},
