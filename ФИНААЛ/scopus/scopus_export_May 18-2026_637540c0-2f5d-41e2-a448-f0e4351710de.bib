@CONFERENCE{Steinbach2025139,
	author = {Steinbach, Marlene and Bhandari, Shreya and Meyer, Jennifer and Pardos, Zachary A.},
	title = {When LLMs Hallucinate: Examining the Effects of Erroneous Feedback in Math Tutoring Systems},
	year = {2025},
	journal = {L@S 2025 - Proceedings of the 12th ACM Conference on Learning @ Scale},
	pages = {139 - 150},
	doi = {10.1145/3698205.3729555},
	url = {https://www.scopus.com/pages/publications/105013074219?origin=resultslist},
	abstract = {Feedback is a powerful tool for enhancing learning, with large language models (LLMs) having the potential to impact educational practices by providing elaborated feedback automatically. However, LLMs are prone to hallucinate and provide erroneous information to a degree. Potential harmful effects of such hallucinations must be explored to fully understand the consequences of introducing LLM-generated feedback in education. We investigate the effects of LLM-generated feedback with hallucinations on learning gain, confusion, time on task, perception of usefulness, and perception of feedback accuracy on mathematics problem solving tasks within an adaptive learning platform based on intelligent tutoring system principles. In our preregistered randomized controlled study (N = 252), learners were assigned to one of four conditions including twelve problems with different proportions of feedback that contained errors: (1) 0% hallucinations (all feedback was accurate), (2) 50% hallucinations (one half of the feedback instances contained errors), (3) 100% hallucinations (all feedback instances contained errors), or (4) no feedback (control condition). Contrary to our hypothesis, learners in the 100% hallucinations feedback condition demonstrated significant learning from pre- to post-test that was not statistically separable from the 0% condition. However, more hallucination led to lower perceived accuracy, lower perceived usefulness, and higher levels of confusion. Prior knowledge moderated the effects only for perceived feedback accuracy. Learners' awareness of errors and higher time on task in the 100% hallucination condition suggests the cognitive mechanism by which learning still occurred. Our study provides initial evidence on the effects of LLM-generated hallucinated feedback with implications for the use of real-time LLM feedback at scale.  © 2025 Owner/Author.},
	author_keywords = {adaptive tutoring; feedback; learning gain; llm hallucination; rct},
	keywords = {Cognitive systems; Computer aided instruction; Education computing; Errors; Feedback control; Learning systems; Teaching; Adaptive tutoring; Condition; Harmful effects; Language model; Learning gain; Llm hallucination; Problem-solving; Rct; Time on tasks; Tutoring system; Problem solving},
	type = {Conference paper},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 4}
}

