@CONFERENCE{Prasertsang2025,
	author = {Prasertsang, Mongkhol and Marwiang, Metta and Junpeng, Putcharee},
	title = {Enhancing Mathematical Conceptual Structure in Number and Algebra through Intelligent Tutoring Systems for Demonstration School of Khon Kaen University Thailand},
	year = {2025},
	journal = {2025 International Technical Conference on Circuits/Systems, Computers, and Communications, ITC-CSCC 2025},
	pages = {},
	doi = {10.1109/ITC-CSCC66376.2025.11137723},
	url = {https://www.scopus.com/pages/publications/105016372375?origin=resultslist},
	abstract = {This research aims to evaluate and compare the developmental scores of mathematical ability in the area of mathematical conceptual structure (SLO) in Strand 1: Numbers and Algebra through an intelligent tutoring system between a control group and an experimental group. The experimental group will utilize a diagnostic system alongside intelligent supplementary lessons via a digital platform and receive automated feedback for improvement developed by the researcher. Meanwhile, the control group will receive instruction using the same diagnostic system and intelligent supplementary lessons via a digital platform but will not receive automated feedback for improvement. This research is conducted at the Demonstration School of Khon Kaen University, with a population of 141 Grade 8th students in the academic year 2024, sampled into experimental and control groups of 32 students each. The tools used include a diagnostic system along with intelligent supplementary lessons via a digital platform. The statistics used for data analysis are mean and standard deviation (SD) and analysis of learning progression by calculating relative gain scores. The research results show that students in the experimental group had a pre-test mean score of 1.38 (SD = 1.63) and a post-test mean score of 3.47 (SD = 0.98), indicating significant improvement in mathematical conceptual structure. In contrast, the control group had a pre-test mean score of 1.63 (SD = 1.41) and a post-test mean score of 3.19 (SD = 1.20). The learning progression score for the experimental group was 85.16% (SD = 20.07), indicating very high development, while the control group had a score of 78.90% (SD = 30.53), also indicating very high development. Although the control group also showed improvement, the overall development level remained lower than that of the experimental group. These findings reflect that the diagnostic system used alongside intelligent supplementary instruction demonstrates the ability to adapt teaching methods to suit the potential and needs of each learner, thereby enhancing mathematical conceptual structure, especially for students with special abilities in mathematics and science. This can serve as a guideline for developing innovative teaching and learning in the future. © 2025 IEEE.},
	author_keywords = {Intelligent Personalized Diagnostic and Tutorial System; Mathematical Conceptual Structure; Number and Algebra},
	keywords = {Computer aided instruction; E-learning; Education computing; Feedback; Students; Teaching; Conceptual structures; Control groups; Diagnostic systems; Digital platforms; Experimental groups; Intelligent personalized diagnostic and tutorial system; Mathematical conceptual structure; Number and algebra; Standard deviation; Tutorial system; Algebra},
	type = {Conference paper},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 0}
}

@ARTICLE{Krumsvik2025113,
	author = {Krumsvik, Rune Johan},
	title = {How capable is GPT-4 at answering exams and tests in Norwegian, and what implications could this have for education?},
	year = {2025},
	journal = {Nordic Journal of Digital Literacy},
	volume = {20},
	number = {2},
	pages = {113 - 133},
	doi = {10.18261/njdl.20.2.5},
	url = {https://www.scopus.com/pages/publications/105017732752?origin=resultslist},
	abstract = {A number of meta-analyses have compared traditional teaching and tutoring with Intelligent Tutoring Systems (ITSs) and have discovered that ITSs can perform well in one-on-one tutoring for students. However, the existing ITSs have not handled the Norwegian language, and although large language models like GPT-4 are not developed as ITSs, they have clear similarities. The purpose of this position paper is to address how GPT-4 handles multilinguistic and cognitive challenges with Norwegian as an exam/test language, descriptive-procedural questions, and various exam and test contexts. This includes exams in medicine, nursing, psychology, dentistry, a theory test for military service, the Norwegian driving test, the Swedish university entrance test, the Norwegian citizenship test, and a national teacher exam in mathematics. A key concern is to investigate what kind of implications this could have for education. The results show that GPT-4 handles multilinguistic challenges well and performs remarkably well in Norwegian within both academic exam tasks and generic IQ and social tests, with elements of both descriptive and procedural questions. With an average precision rate of 94.26%, GPT-4’s performance demonstrates a high degree of reliability. This is partly consistent with the international knowledge base in some areas, but the study differs from this by confirming that it also masters Norwegian exam and test contexts very well. Thus, it has the ability to adapt linguistically and culturally, something conventional ITSs do not possess. GPT-4 (Spring 2024) is also capable of conducting multimodal analyses of medical images in Norwegian, and handles minority languages in Sami, which ITSs usually cannot do. Despite certain limitations, the position paper claims that such findings contribute to a broader understanding GPT-4’s multilinguistic and cognitive capabilities in formative and summative assessment contexts. Therefore, this position paper argues that it has significant implications for various aspects of the educational sector. © 2025 Author(s). This is an open access article distributed under the terms of the Creative Commons CC-BY 4.0 License},
	author_keywords = {AI; exams; GPT-4; multilingualism; Norwegian; performance},
	type = {Article},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 1; All Open Access; Gold Open Access}
}

@ARTICLE{Chukhray2025151,
	author = {Chukhray, Andriy and Yevdokymov, Oleksandr and Mandrikova, Liudmila and Dehtiarova, Tetiana and Havrylenko, Olena},
	title = {Diagnostic Models and a Crypto-Based Sense-Economic Approach to Enhancing Motivation in Intelligent Mathematics Learning Systems},
	year = {2025},
	journal = {Communications in Computer and Information Science},
	volume = {2763 CCIS},
	pages = {151 - 167},
	doi = {10.1007/978-3-032-10477-9_11},
	url = {https://www.scopus.com/pages/publications/105027093272?origin=resultslist},
	abstract = {This paper explores the development of diagnostic models within intelligent educational systems, with a focus on mathematical disciplines. A comparative analysis of discrete and continuous knowledge tracing approaches is presented, highlighting their strengths in adapting to students’ cognitive profiles and uncovering latent skill dynamics. In parallel, the paper introduces a novel sense-economic model that aims to enhance student motivation by recognizing meaningful contributions to learning. Educational progress is measured not solely through correctness but through deeper indicators such as analytical reasoning, conceptual understanding, creative problem-solving, and peer support. A central component of this approach is the implementation of a unified blockchain-based token (SenseCoin), which operates within a decentralized infrastructure of validated educational values—termed “senses.” These tokens are awarded based on transparent, configurable criteria and can be exchanged for intrinsically valuable educational opportunities, such as access to premium learning resources, project-based modules, or mentorship-driven activities. The model supports a dynamic ontology of sense types, allowing flexible expansion across domains and disciplines. The paper argues that the combination of diagnostic precision and value-sensitive tokenization offers a promising direction for the future of educational systems—one grounded in personal meaning, autonomy, and integrity rather than coercion or formal compliance. © The Author(s), under exclusive license to Springer Nature Switzerland AG 2025.},
	author_keywords = {Crypto Tokens in Education; Diagnostic Models; Intelligent Tutoring Systems; Sense-Economic Model; Student Motivation},
	keywords = {Blockchain; Computer aided instruction; E-learning; Education computing; Intelligent systems; Learning systems; Ontology; Students; Crypto token in education; Diagnostic model; Economic approach; Economic models; Intelligent tutoring; Intelligent tutoring system; Mathematics learning; Sense-economic model; Student motivation; Tutoring system; Motivation},
	type = {Conference paper},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 0}
}

