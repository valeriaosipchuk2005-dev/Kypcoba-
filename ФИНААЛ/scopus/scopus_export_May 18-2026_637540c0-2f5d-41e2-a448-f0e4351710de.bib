	keywords = {Computer aided instruction; Curricula; Education computing; Motivation; Students; Teaching; Experimental study; Gamified intelligent tutoring system; Higher School; Intelligent tutoring; Mathematics education; Mathematics teachings; Problem solving motivation; Problem-solving; Student motivation; Tutoring system; Problem solving},
