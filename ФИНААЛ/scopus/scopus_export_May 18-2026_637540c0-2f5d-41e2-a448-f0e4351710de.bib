	title = {Evaluating an AI Teaching Assistant in VR Physics Education: A Case Study of User Experience and Effectiveness},
	year = {2025},
	journal = {Proceedings - 2025 IEEE International Symposium on Emerging Metaverse, ISEMV 2025},
	pages = {62 - 68},
